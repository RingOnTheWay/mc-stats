<script setup lang="ts">
import { ref, onMounted, computed } from 'vue'
import { useI18n } from 'vue-i18n'
import { apiPost, apiDelete, apiGet } from '@/services/api'
import { Upload, Download, Trash2, RefreshCw, Database, Loader2 } from 'lucide-vue-next'

const { t } = useI18n()

const activeTab = ref<'import' | 'export' | 'manage'>('import')

const scanFolder = ref('')
const scanDate = ref(new Date().toISOString().slice(0, 10))
const scanLoading = ref(false)
const scanResult = ref<any>(null)
const scanError = ref('')

const batchFolder = ref('')
const batchLoading = ref(false)
const batchResult = ref<any>(null)
const batchError = ref('')

const exportLoading = ref(false)
const exportResult = ref<any>(null)
const exportError = ref('')

const dates = ref<string[]>([])
const datesLoading = ref(false)
const selectedDates = ref<Set<string>>(new Set())
const deleteLoading = ref(false)
const deleteResult = ref<any>(null)
const deleteError = ref('')

const deleteDate = ref('')
const deleteSingleLoading = ref(false)
const deleteSingleResult = ref<any>(null)
const deleteSingleError = ref('')

onMounted(() => { loadDates() })

async function loadDates() {
  datesLoading.value = true
  try {
    dates.value = await apiGet<string[]>('/api/dates')
  } catch {
    dates.value = []
  } finally {
    datesLoading.value = false
  }
}

async function handleScan() {
  if (!scanFolder.value.trim()) return
  scanLoading.value = true
  scanResult.value = null
  scanError.value = ''
  try {
    const body: Record<string, string> = { folder: scanFolder.value.trim() }
    if (scanDate.value) body.date = scanDate.value
    scanResult.value = await apiPost('/api/scan', body)
  } catch (e: any) {
    scanError.value = e.message || t('dataManage.operationFailed')
  } finally {
    scanLoading.value = false
  }
}

async function handleBatchScan() {
  if (!batchFolder.value.trim()) return
  batchLoading.value = true
  batchResult.value = null
  batchError.value = ''
  try {
    batchResult.value = await apiPost('/api/batch_scan', { parent_folder: batchFolder.value.trim() })
  } catch (e: any) {
    batchError.value = e.message || t('dataManage.operationFailed')
  } finally {
    batchLoading.value = false
  }
}

async function handleExport() {
  exportLoading.value = true
  exportResult.value = null
  exportError.value = ''
  try {
    exportResult.value = await apiPost('/api/export', {})
  } catch (e: any) {
    exportError.value = e.message || t('dataManage.operationFailed')
  } finally {
    exportLoading.value = false
  }
}

async function handleDeleteSingle() {
  if (!deleteDate.value) return
  deleteSingleLoading.value = true
  deleteSingleResult.value = null
  deleteSingleError.value = ''
  try {
    deleteSingleResult.value = await apiDelete('/api/delete_date', { date: deleteDate.value })
    await loadDates()
  } catch (e: any) {
    deleteSingleError.value = e.message || t('dataManage.operationFailed')
  } finally {
    deleteSingleLoading.value = false
  }
}

async function handleBatchDelete() {
  if (selectedDates.value.size === 0) return
  deleteLoading.value = true
  deleteResult.value = null
  deleteError.value = ''
  try {
    deleteResult.value = await apiDelete('/api/batch_delete', { dates: Array.from(selectedDates.value) })
    selectedDates.value.clear()
    await loadDates()
  } catch (e: any) {
    deleteError.value = e.message || t('dataManage.operationFailed')
  } finally {
    deleteLoading.value = false
  }
}

function toggleDate(d: string) {
  if (selectedDates.value.has(d)) {
    selectedDates.value.delete(d)
  } else {
    selectedDates.value.add(d)
  }
}

function selectAllDates() {
  dates.value.forEach(d => selectedDates.value.add(d))
}

function deselectAllDates() {
  selectedDates.value.clear()
}

const allDatesSelected = computed(() => dates.value.length > 0 && selectedDates.value.size === dates.value.length)
</script>

<template>
  <div class="space-y-6">
    <div class="flex gap-2">
      <button
        v-for="tab in (['import', 'export', 'manage'] as const)"
        :key="tab"
        class="px-5 py-2 rounded-lg text-sm font-medium transition-all duration-200"
        :class="activeTab === tab
          ? 'subnav-active'
          : 'subnav-inactive'"
        @click="activeTab = tab"
      >
        {{ t(`dataManage.${tab}Tab`) }}
      </button>
    </div>

    <div v-if="activeTab === 'import'" class="space-y-6">
      <div class="relative bg-white/70 backdrop-blur-sm rounded-2xl p-8 border border-white/80 shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden group">
        <div class="absolute top-0 right-0 w-64 h-64 bg-gradient-to-br from-brand/5 to-transparent rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700" />

        <div class="relative">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 bg-gradient-to-br from-brand/20 to-brand/10 rounded-xl flex items-center justify-center">
              <Upload class="w-6 h-6 text-brand" />
            </div>
            <h3 class="text-lg font-semibold text-slate-800">{{ t('dataManage.singleScan') }}</h3>
          </div>

          <div class="space-y-4">
            <div>
              <label class="block mb-2 text-sm font-medium text-slate-600">{{ t('dataManage.serverFolder') }}</label>
              <input v-model="scanFolder" type="text" :placeholder="t('dataManage.folderPlaceholder')" class="w-full px-4 py-3 bg-white/80 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand/20 focus:border-brand/40 transition-all" />
            </div>
            <div>
              <label class="block mb-2 text-sm font-medium text-slate-600">{{ t('dataManage.scanDate') }}</label>
              <input v-model="scanDate" type="date" class="w-full px-4 py-3 bg-white/80 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand/20 focus:border-brand/40 transition-all" />
            </div>
            <button
              class="inline-flex items-center gap-2 px-6 py-3 bg-brand hover:bg-brand/90 text-white rounded-xl text-sm font-medium transition-all disabled:opacity-50 disabled:cursor-not-allowed"
              :disabled="scanLoading || !scanFolder.trim()"
              @click="handleScan"
            >
              <Loader2 v-if="scanLoading" class="w-4 h-4 animate-spin" />
              <Upload v-else class="w-4 h-4" />
              {{ scanLoading ? t('common.loading') : t('dataManage.startScan') }}
            </button>
          </div>

          <div v-if="scanError" class="mt-4 p-4 bg-red-50 border border-red-100 rounded-xl text-sm text-red-700">{{ scanError }}</div>
          <div v-if="scanResult" class="mt-4 p-4 bg-emerald-50 border border-emerald-100 rounded-xl">
            <div class="font-semibold text-emerald-800 text-sm mb-2">{{ t('dataManage.scanSuccess') }}</div>
            <div class="flex flex-wrap gap-3 text-xs text-emerald-700">
              <span>{{ t('dataManage.date') }}: {{ scanResult.date }}</span>
              <span>{{ t('dataManage.playerCount') }}: {{ scanResult.player_count }}</span>
              <span>{{ t('dataManage.battleCount') }}: {{ scanResult.battle_stats_count }}</span>
              <span>{{ t('dataManage.craftCount') }}: {{ scanResult.craft_stats_count }}</span>
              <span>{{ t('dataManage.itemCount') }}: {{ scanResult.item_stats_count }}</span>
            </div>
          </div>
        </div>
      </div>

      <div class="relative bg-white/70 backdrop-blur-sm rounded-2xl p-8 border border-white/80 shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden group">
        <div class="absolute top-0 right-0 w-64 h-64 bg-gradient-to-br from-brand/5 to-transparent rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700" />

        <div class="relative">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 bg-gradient-to-br from-brand/20 to-brand/10 rounded-xl flex items-center justify-center">
              <Database class="w-6 h-6 text-brand" />
            </div>
            <h3 class="text-lg font-semibold text-slate-800">{{ t('dataManage.batchScan') }}</h3>
          </div>

          <div class="space-y-4">
            <div>
              <label class="block mb-2 text-sm font-medium text-slate-600">{{ t('dataManage.parentFolder') }}</label>
              <input v-model="batchFolder" type="text" :placeholder="t('dataManage.parentFolderPlaceholder')" class="w-full px-4 py-3 bg-white/80 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-brand/20 focus:border-brand/40 transition-all" />
            </div>
            <p class="text-xs text-slate-500">{{ t('dataManage.batchHint') }}</p>
            <button
              class="inline-flex items-center gap-2 px-6 py-3 bg-brand hover:bg-brand/90 text-white rounded-xl text-sm font-medium transition-all disabled:opacity-50 disabled:cursor-not-allowed"
              :disabled="batchLoading || !batchFolder.trim()"
              @click="handleBatchScan"
            >
              <Loader2 v-if="batchLoading" class="w-4 h-4 animate-spin" />
              <Upload v-else class="w-4 h-4" />
              {{ batchLoading ? t('common.loading') : t('dataManage.startBatchScan') }}
            </button>
          </div>

          <div v-if="batchError" class="mt-4 p-4 bg-red-50 border border-red-100 rounded-xl text-sm text-red-700">{{ batchError }}</div>
          <div v-if="batchResult" class="mt-4 p-4 bg-emerald-50 border border-emerald-100 rounded-xl">
            <div class="font-semibold text-emerald-800 text-sm mb-2">{{ t('dataManage.batchScanSuccess') }}</div>
            <pre class="text-xs text-emerald-700 whitespace-pre-wrap break-all max-h-60 overflow-y-auto">{{ JSON.stringify(batchResult, null, 2) }}</pre>
          </div>
        </div>
      </div>
    </div>

    <div v-if="activeTab === 'export'" class="space-y-6">
      <div class="relative bg-white/70 backdrop-blur-sm rounded-2xl p-8 border border-white/80 shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden group">
        <div class="absolute top-0 right-0 w-64 h-64 bg-gradient-to-br from-brand/5 to-transparent rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700" />

        <div class="relative">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 bg-gradient-to-br from-brand/20 to-brand/10 rounded-xl flex items-center justify-center">
              <Download class="w-6 h-6 text-brand" />
            </div>
            <h3 class="text-lg font-semibold text-slate-800">{{ t('dataManage.exportTitle') }}</h3>
          </div>

          <p class="text-sm text-slate-500 mb-4">{{ t('dataManage.exportHint') }}</p>
          <button
            class="inline-flex items-center gap-2 px-6 py-3 bg-brand hover:bg-brand/90 text-white rounded-xl text-sm font-medium transition-all disabled:opacity-50 disabled:cursor-not-allowed"
            :disabled="exportLoading"
            @click="handleExport"
          >
            <Loader2 v-if="exportLoading" class="w-4 h-4 animate-spin" />
            <Download v-else class="w-4 h-4" />
            {{ exportLoading ? t('common.loading') : t('dataManage.startExport') }}
          </button>

          <div v-if="exportError" class="mt-4 p-4 bg-red-50 border border-red-100 rounded-xl text-sm text-red-700">{{ exportError }}</div>
          <div v-if="exportResult" class="mt-4 p-4 bg-emerald-50 border border-emerald-100 rounded-xl">
            <div class="font-semibold text-emerald-800 text-sm">{{ exportResult.message || t('dataManage.exportSuccess') }}</div>
          </div>
        </div>
      </div>
    </div>

    <div v-if="activeTab === 'manage'" class="space-y-6">
      <div class="relative bg-white/70 backdrop-blur-sm rounded-2xl p-8 border border-white/80 shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden group">
        <div class="absolute top-0 right-0 w-64 h-64 bg-gradient-to-br from-brand/5 to-transparent rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700" />

        <div class="relative">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 bg-gradient-to-br from-red-500/20 to-red-500/10 rounded-xl flex items-center justify-center">
              <Trash2 class="w-6 h-6 text-red-500" />
            </div>
            <h3 class="text-lg font-semibold text-slate-800">{{ t('dataManage.deleteByDate') }}</h3>
          </div>

          <div class="space-y-4">
            <div>
              <label class="block mb-2 text-sm font-medium text-slate-600">{{ t('dataManage.selectDate') }}</label>
              <input v-model="deleteDate" type="date" class="w-full px-4 py-3 bg-white/80 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-red-200 focus:border-red-300 transition-all" />
            </div>
            <button
              class="inline-flex items-center gap-2 px-6 py-3 bg-red-500 hover:bg-red-600 text-white rounded-xl text-sm font-medium transition-all disabled:opacity-50 disabled:cursor-not-allowed"
              :disabled="deleteSingleLoading || !deleteDate"
              @click="handleDeleteSingle"
            >
              <Loader2 v-if="deleteSingleLoading" class="w-4 h-4 animate-spin" />
              <Trash2 v-else class="w-4 h-4" />
              {{ deleteSingleLoading ? t('common.loading') : t('dataManage.confirmDelete') }}
            </button>
          </div>

          <div v-if="deleteSingleError" class="mt-4 p-4 bg-red-50 border border-red-100 rounded-xl text-sm text-red-700">{{ deleteSingleError }}</div>
          <div v-if="deleteSingleResult" class="mt-4 p-4 bg-emerald-50 border border-emerald-100 rounded-xl">
            <div class="font-semibold text-emerald-800 text-sm mb-2">{{ t('dataManage.deleteSuccess', { date: deleteSingleResult.date }) }}</div>
            <div class="flex flex-wrap gap-3 text-xs text-emerald-700">
              <span>{{ t('dataManage.mapDeleted') }}: {{ deleteSingleResult.map_records_deleted }}</span>
              <span>{{ t('dataManage.playerDeleted') }}: {{ deleteSingleResult.player_records_deleted }}</span>
              <span>{{ t('dataManage.detailDeleted') }}: {{ deleteSingleResult.detail_records_deleted }}</span>
            </div>
          </div>
        </div>
      </div>

      <div class="relative bg-white/70 backdrop-blur-sm rounded-2xl p-8 border border-white/80 shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden group">
        <div class="absolute top-0 right-0 w-64 h-64 bg-gradient-to-br from-brand/5 to-transparent rounded-full blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700" />

        <div class="relative">
          <div class="flex items-center gap-4 mb-6">
            <div class="w-12 h-12 bg-gradient-to-br from-red-500/20 to-red-500/10 rounded-xl flex items-center justify-center">
              <Trash2 class="w-6 h-6 text-red-500" />
            </div>
            <h3 class="text-lg font-semibold text-slate-800">{{ t('dataManage.batchDelete') }}</h3>
          </div>

          <div class="flex items-center gap-2 mb-4 flex-wrap">
            <button class="px-3 py-1.5 bg-brand/10 text-brand rounded-lg text-xs font-medium hover:bg-brand/20 transition-all" @click="selectAllDates" :disabled="dates.length === 0">{{ t('common.selectAll') }}</button>
            <button class="px-3 py-1.5 bg-brand/10 text-brand rounded-lg text-xs font-medium hover:bg-brand/20 transition-all" @click="deselectAllDates" :disabled="selectedDates.size === 0">{{ t('common.deselectAll') }}</button>
            <span class="text-xs text-slate-500 ml-auto">{{ t('dataManage.selectedCount', { n: selectedDates.size }) }}</span>
            <button class="p-1.5 hover:bg-slate-100 rounded-lg transition-all" @click="loadDates" :disabled="datesLoading">
              <RefreshCw class="w-4 h-4 text-slate-500" :class="{ 'animate-spin': datesLoading }" />
            </button>
          </div>

          <div v-if="datesLoading" class="py-8 text-center text-sm text-slate-500">{{ t('common.loading') }}</div>
          <div v-else-if="dates.length === 0" class="py-8 text-center text-sm text-slate-500">{{ t('common.noData') }}</div>
          <div v-else class="flex flex-wrap gap-2 max-h-72 overflow-y-auto">
            <label
              v-for="d in dates"
              :key="d"
              class="inline-flex items-center gap-2 px-3 py-2 rounded-lg text-sm cursor-pointer transition-all border"
              :class="selectedDates.has(d)
                ? 'bg-brand/10 text-brand border-brand/30'
                : 'bg-white/80 text-slate-600 border-slate-200 hover:bg-white'"
            >
              <input type="checkbox" :checked="selectedDates.has(d)" @change="toggleDate(d)" class="accent-brand" />
              <span>{{ d }}</span>
            </label>
          </div>

          <button
            class="mt-4 inline-flex items-center gap-2 px-6 py-3 bg-red-500 hover:bg-red-600 text-white rounded-xl text-sm font-medium transition-all disabled:opacity-50 disabled:cursor-not-allowed"
            :disabled="deleteLoading || selectedDates.size === 0"
            @click="handleBatchDelete"
          >
            <Loader2 v-if="deleteLoading" class="w-4 h-4 animate-spin" />
            <Trash2 v-else class="w-4 h-4" />
            {{ deleteLoading ? t('common.loading') : t('dataManage.confirmBatchDelete', { n: selectedDates.size }) }}
          </button>

          <div v-if="deleteError" class="mt-4 p-4 bg-red-50 border border-red-100 rounded-xl text-sm text-red-700">{{ deleteError }}</div>
          <div v-if="deleteResult" class="mt-4 p-4 bg-emerald-50 border border-emerald-100 rounded-xl">
            <div class="font-semibold text-emerald-800 text-sm mb-2">{{ t('dataManage.batchDeleteSuccess') }}</div>
            <div class="flex flex-wrap gap-3 text-xs text-emerald-700">
              <span>{{ t('dataManage.totalDates') }}: {{ deleteResult.total_dates }}</span>
              <span>{{ t('dataManage.mapDeleted') }}: {{ deleteResult.total_map_deleted }}</span>
              <span>{{ t('dataManage.playerDeleted') }}: {{ deleteResult.total_player_deleted }}</span>
              <span>{{ t('dataManage.detailDeleted') }}: {{ deleteResult.total_detail_deleted }}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</template>
